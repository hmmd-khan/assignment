public class l5{
public static void main(String[]args){
    for(int i=1;i<=5;i++){
        for(int j=5;j>=i+1;j--){
            System.out.print(" ");
        }
        for(int k=i;k>=1;k--){
            System.out.print(k);
            if(k==1){
                for(int j=2;j<=i;j++){
                    System.out.print(j);
                }
            }
        }
        System.out.println();
    }
}
}
